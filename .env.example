# =============================================================================
# APPWRITE — Self-hosted
# =============================================================================

# URL pública da sua instância Appwrite (sem barra final)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://appwrite.example.com/v1

# ID do projeto Appwrite
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-project-id

# API Key com escopo admin (usado apenas no servidor / Appwrite Functions)
# NUNCA exponha esta chave no frontend
APPWRITE_API_KEY=your-appwrite-api-key

# ID do database principal
NEXT_PUBLIC_APPWRITE_DATABASE_ID=acadbook

# IDs das collections
NEXT_PUBLIC_APPWRITE_COLLECTION_BOOKS=books
NEXT_PUBLIC_APPWRITE_COLLECTION_BOOK_PLANS=book_plans
NEXT_PUBLIC_APPWRITE_COLLECTION_CHAPTERS=chapters
NEXT_PUBLIC_APPWRITE_COLLECTION_SOURCES=sources
NEXT_PUBLIC_APPWRITE_COLLECTION_REFERENCES=references
NEXT_PUBLIC_APPWRITE_COLLECTION_EXPORTS=exports
NEXT_PUBLIC_APPWRITE_COLLECTION_GENERATION_LOGS=generation_logs

# ID do bucket de storage para PDFs
NEXT_PUBLIC_APPWRITE_STORAGE_BUCKET_ID=book-exports

# =============================================================================
# APPWRITE FUNCTIONS — IDs das functions deployadas
# =============================================================================

APPWRITE_FUNCTION_GENERATE_PLAN=generate-book-plan
APPWRITE_FUNCTION_RESEARCH_CHAPTER=research-chapter
APPWRITE_FUNCTION_GENERATE_CHAPTER=generate-chapter
APPWRITE_FUNCTION_ASSEMBLE_BOOK=assemble-book
APPWRITE_FUNCTION_EXPORT_PDF=export-pdf
APPWRITE_FUNCTION_RETRY_GENERATION=retry-generation

# =============================================================================
# PERPLEXITY API
# =============================================================================

# Chave de API da Perplexity — NUNCA exponha no frontend
PERPLEXITY_API_KEY=pplx-your-api-key

# Modelo da Perplexity (sonar-pro recomendado para citações estruturadas)
PERPLEXITY_MODEL=sonar-pro

# URL base da API Perplexity
PERPLEXITY_API_URL=https://api.perplexity.ai

# =============================================================================
# MINIMAX API
# =============================================================================

# Chave de API MiniMax (global) — NUNCA exponha no frontend
MINIMAX_API_KEY=your-minimax-api-key

# URL base da API MiniMax (endpoint global)
MINIMAX_API_URL=https://api.minimaxi.com/v1

# Modelo MiniMax para geração de texto acadêmico
MINIMAX_MODEL=MiniMax-Text-01

# =============================================================================
# NEXT.JS
# =============================================================================

# URL base da aplicação (sem barra final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Segredo para assinar tokens internos (mín. 32 caracteres)
INTERNAL_SECRET=change-me-to-a-random-32-char-string

# =============================================================================
# LIMITES DE USO (opcionais — controle de créditos)
# =============================================================================

# Máximo de livros por usuário
MAX_BOOKS_PER_USER=10

# Máximo de tentativas de geração por capítulo
MAX_GENERATION_RETRIES=3

# Timeout em milissegundos para chamadas às APIs de IA
AI_REQUEST_TIMEOUT_MS=60000
